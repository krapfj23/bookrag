    },
    {
      "question": "Who was Scrooge's business partner?",
      "expected_answer_contains": ["Marley", "Jacob Marley"],
      "expected_answer_not_contains": ["Bob Cratchit"]
    },
    {
      "question": "Who is Tiny Tim's father?",
